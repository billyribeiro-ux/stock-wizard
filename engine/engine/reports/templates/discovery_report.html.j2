<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<style>
  @page { size: A4; margin: 1.6cm; }
  body { font-family: "Helvetica Neue", Arial, sans-serif; color: #1a1d23; font-size: 11px; }
  h1 { font-size: 20px; margin: 0 0 2px; }
  h2 { font-size: 13px; margin: 16px 0 6px; border-bottom: 1px solid #d7dbe0; padding-bottom: 3px; }
  .muted { color: #6b7280; }
  .cover { border-bottom: 3px solid #2563eb; padding-bottom: 10px; margin-bottom: 12px; }
  .grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 8px; }
  .card { border: 1px solid #e5e7eb; border-radius: 6px; padding: 8px; }
  .card .label { font-size: 9px; text-transform: uppercase; color: #64748b; }
  .card .value { font-size: 15px; font-weight: 700; }
  table { width: 100%; border-collapse: collapse; margin-top: 4px; }
  th, td { text-align: left; padding: 3px 6px; border-bottom: 1px solid #eef1f4; }
  th { background: #f8fafc; font-size: 9px; text-transform: uppercase; color: #64748b; }
  .pos { color: #166534; } .neg { color: #991b1b; }
  .pill { display: inline-block; padding: 1px 7px; border-radius: 10px; font-size: 10px; font-weight: 600; }
  .bought { background: #dcfce7; color: #166534; }
  .sold { background: #fee2e2; color: #991b1b; }
  .footer { margin-top: 20px; font-size: 9px; color: #9ca3af; }
</style>
</head>
<body>
  <div class="cover">
    <h1>Self-Learning Discovery — {{ r.symbol }}</h1>
    <div class="muted">
      {{ r.timeframe }} ({{ r.trade_style|replace('_',' ') }}) ·
      {{ r.period_start[:10] }} → {{ r.period_end[:10] }} ·
      {{ r.n_bars }} bars · generated {{ generated_at }}
    </div>
  </div>

  <div class="grid">
    <div class="card"><div class="label">Turning points</div><div class="value">{{ r.n_events }}</div></div>
    <div class="card"><div class="label">Bought (bottoms)</div><div class="value pos">{{ r.n_bought }}</div></div>
    <div class="card"><div class="label">Sold (tops)</div><div class="value neg">{{ r.n_sold }}</div></div>
    <div class="card"><div class="label">Style</div><div class="value">{{ r.trade_style|replace('_',' ') }}</div></div>
  </div>

  <h2>Why it was BOUGHT — reasons ranked by frequency × forward move</h2>
  <table>
    <thead><tr><th>Reason</th><th>Count</th><th>% of bottoms</th><th>Avg forward move</th></tr></thead>
    <tbody>
    {% for s in r.buy_reasons %}
      <tr><td>{{ s.label }}</td><td>{{ s.count }}</td><td>{{ '%.0f%%'|format(s.pct_of_events*100) }}</td>
          <td class="pos">{{ '%+.2f%%'|format(s.avg_forward_move_pct*100) }}</td></tr>
    {% endfor %}
    </tbody>
  </table>

  <h2>Why it was SOLD — reasons ranked by frequency × forward move</h2>
  <table>
    <thead><tr><th>Reason</th><th>Count</th><th>% of tops</th><th>Avg forward move</th></tr></thead>
    <tbody>
    {% for s in r.sell_reasons %}
      <tr><td>{{ s.label }}</td><td>{{ s.count }}</td><td>{{ '%.0f%%'|format(s.pct_of_events*100) }}</td>
          <td class="neg">{{ '%+.2f%%'|format(s.avg_forward_move_pct*100) }}</td></tr>
    {% endfor %}
    </tbody>
  </table>

  <h2>Event sample (latest {{ sample|length }})</h2>
  <table>
    <thead><tr><th>Time</th><th>Turn</th><th>Price</th><th>Forward move</th><th>Self-identified reasons</th></tr></thead>
    <tbody>
    {% for e in sample %}
      <tr>
        <td>{{ e.ts[:16] }}</td>
        <td><span class="pill {{ e.kind }}">{{ e.kind|upper }}</span></td>
        <td>{{ e.price }}</td>
        <td class="{{ 'pos' if e.kind == 'bought' else 'neg' }}">{{ '%+.2f%%'|format(e.forward_move_pct*100) }} ({{ e.forward_move_atr }} ATR)</td>
        <td>{{ e.reasons | map(attribute='label') | join(', ') }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>

  <div class="footer">
    Stock Wizard self-learning discovery. Reasons are evidence present at each historical
    turn; they describe what happened, and become tradeable only after walk-forward and
    forward testing. Not financial advice.
  </div>
</body>
</html>
