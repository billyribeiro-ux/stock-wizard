# ---- Database (Postgres + TimescaleDB) ----
DATABASE_URL=postgresql+asyncpg://wizard:wizard@localhost:5432/stockwizard
DATABASE_URL_SYNC=postgresql+psycopg://wizard:wizard@localhost:5432/stockwizard
POSTGRES_USER=wizard
POSTGRES_PASSWORD=wizard
POSTGRES_DB=stockwizard

# ---- Redis (queue / pubsub / cache) ----
REDIS_URL=redis://localhost:6379/0

# ---- API auth ----
# Shared secret the SvelteKit server uses to call FastAPI. NEVER shipped to the browser.
INTERNAL_API_TOKEN=dev-token-change-me

# ---- Vendor API key encryption ----
# 32-byte urlsafe-base64 Fernet key. Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If this key is lost, ALL stored vendor API keys are unrecoverable by design.
MASTER_KEY=
# Optional previous key to support rotation / re-encryption.
MASTER_KEY_PREVIOUS=

# ---- Market data ----
# Annualized risk-free rate used for Black-Scholes greeks when ^IRX is unavailable.
RISK_FREE_RATE=0.0525
DEFAULT_EXCHANGE_TZ=America/New_York

# ---- Frontend (apps/web) ----
API_BASE_URL=http://localhost:8000
