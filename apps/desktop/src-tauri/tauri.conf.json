{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stock Wizard",
  "version": "0.1.0",
  "identifier": "com.stockwizard.desktop",
  "build": {
    "frontendDist": "../../web/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --dir ../../web dev",
    "beforeBuildCommand": "pnpm --dir ../../web build"
  },
  "app": {
    "windows": [
      {
        "title": "Stock Wizard",
        "width": 1480,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"]
  }
}
