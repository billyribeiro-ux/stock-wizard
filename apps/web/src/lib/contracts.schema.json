{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "StockWizardContracts",
	"$defs": {
		"BarFlag": {
			"description": "Data-quality annotations attached to a bar by the validator.",
			"enum": ["GAP", "SPLIT_SUSPECT", "ZERO_VOLUME", "OUT_OF_HOURS", "IMPOSSIBLE", "DUPLICATE"],
			"title": "BarFlag",
			"type": "string"
		},
		"Timeframe": {
			"description": "Bar granularities. Values match common vendor strings.",
			"enum": ["1m", "5m", "15m", "30m", "1h", "4h", "1d", "1wk", "1mo"],
			"title": "Timeframe",
			"type": "string"
		},
		"MarketBar": {
			"additionalProperties": false,
			"description": "A single OHLCV bar from one source.",
			"properties": {
				"symbol": {
					"title": "Symbol",
					"type": "string"
				},
				"timeframe": {
					"$ref": "#/$defs/Timeframe"
				},
				"ts": {
					"description": "Bar open time, tz-aware UTC",
					"format": "date-time",
					"title": "Ts",
					"type": "string"
				},
				"open": {
					"anyOf": [
						{
							"type": "number"
						},
						{
							"pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
							"type": "string"
						}
					],
					"title": "Open"
				},
				"high": {
					"anyOf": [
						{
							"type": "number"
						},
						{
							"pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
							"type": "string"
						}
					],
					"title": "High"
				},
				"low": {
					"anyOf": [
						{
							"type": "number"
						},
						{
							"pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
							"type": "string"
						}
					],
					"title": "Low"
				},
				"close": {
					"anyOf": [
						{
							"type": "number"
						},
						{
							"pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
							"type": "string"
						}
					],
					"title": "Close"
				},
				"volume": {
					"minimum": 0,
					"title": "Volume",
					"type": "integer"
				},
				"vwap": {
					"anyOf": [
						{
							"type": "number"
						},
						{
							"pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
							"type": "string"
						},
						{
							"type": "null"
						}
					],
					"default": null,
					"title": "Vwap"
				},
				"source": {
					"default": "yfinance",
					"title": "Source",
					"type": "string"
				},
				"is_adjusted": {
					"default": false,
					"title": "Is Adjusted",
					"type": "boolean"
				},
				"quality_flags": {
					"items": {
						"$ref": "#/$defs/BarFlag"
					},
					"title": "Quality Flags",
					"type": "array"
				}
			},
			"required": ["symbol", "timeframe", "ts", "open", "high", "low", "close", "volume"],
			"title": "MarketBar",
			"type": "object"
		},
		"AssetClass": {
			"enum": ["equity", "etf", "index", "future", "option", "crypto", "fx"],
			"title": "AssetClass",
			"type": "string"
		},
		"OHLCV": {
			"additionalProperties": false,
			"description": "Ordered series of bars for one symbol/timeframe/source.",
			"properties": {
				"symbol": {
					"title": "Symbol",
					"type": "string"
				},
				"timeframe": {
					"$ref": "#/$defs/Timeframe"
				},
				"asset_class": {
					"$ref": "#/$defs/AssetClass",
					"default": "equity"
				},
				"source": {
					"default": "yfinance",
					"title": "Source",
					"type": "string"
				},
				"bars": {
					"items": {
						"$ref": "#/$defs/MarketBar"
					},
					"title": "Bars",
					"type": "array"
				}
			},
			"required": ["symbol", "timeframe"],
			"title": "OHLCV",
			"type": "object"
		},
		"Greeks": {
			"additionalProperties": false,
			"properties": {
				"delta": {
					"title": "Delta",
					"type": "number"
				},
				"gamma": {
					"title": "Gamma",
					"type": "number"
				},
				"theta": {
					"title": "Theta",
					"type": "number"
				},
				"vega": {
					"title": "Vega",
					"type": "number"
				},
				"rho": {
					"default": 0.0,
					"title": "Rho",
					"type": "number"
				},
				"iv": {
					"title": "Iv",
					"type": "number"
				},
				"computed": {
					"default": true,
					"description": "True when we solved these (e.g. from yfinance chain)",
					"title": "Computed",
					"type": "boolean"
				}
			},
			"required": ["delta", "gamma", "theta", "vega", "iv"],
			"title": "Greeks",
			"type": "object"
		},
		"OptionContract": {
			"additionalProperties": false,
			"properties": {
				"underlying": {
					"title": "Underlying",
					"type": "string"
				},
				"expiry": {
					"format": "date",
					"title": "Expiry",
					"type": "string"
				},
				"strike": {
					"anyOf": [
						{
							"type": "number"
						},
						{
							"pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
							"type": "string"
						}
					],
					"title": "Strike"
				},
				"right": {
					"$ref": "#/$defs/OptionRight"
				},
				"bid": {
					"anyOf": [
						{
							"type": "number"
						},
						{
							"pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
							"type": "string"
						},
						{
							"type": "null"
						}
					],
					"default": null,
					"title": "Bid"
				},
				"ask": {
					"anyOf": [
						{
							"type": "number"
						},
						{
							"pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
							"type": "string"
						},
						{
							"type": "null"
						}
					],
					"default": null,
					"title": "Ask"
				},
				"last": {
					"anyOf": [
						{
							"type": "number"
						},
						{
							"pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
							"type": "string"
						},
						{
							"type": "null"
						}
					],
					"default": null,
					"title": "Last"
				},
				"volume": {
					"default": 0,
					"minimum": 0,
					"title": "Volume",
					"type": "integer"
				},
				"open_interest": {
					"default": 0,
					"minimum": 0,
					"title": "Open Interest",
					"type": "integer"
				},
				"iv": {
					"anyOf": [
						{
							"type": "number"
						},
						{
							"type": "null"
						}
					],
					"default": null,
					"title": "Iv"
				},
				"greeks": {
					"anyOf": [
						{
							"$ref": "#/$defs/Greeks"
						},
						{
							"type": "null"
						}
					],
					"default": null
				},
				"multiplier": {
					"default": 100,
					"title": "Multiplier",
					"type": "integer"
				},
				"as_of": {
					"format": "date-time",
					"title": "As Of",
					"type": "string"
				}
			},
			"required": ["underlying", "expiry", "strike", "right", "as_of"],
			"title": "OptionContract",
			"type": "object"
		},
		"OptionRight": {
			"enum": ["C", "P"],
			"title": "OptionRight",
			"type": "string"
		},
		"OptionChain": {
			"additionalProperties": false,
			"description": "Snapshot of an underlying's option chain at ``as_of``.",
			"properties": {
				"underlying": {
					"title": "Underlying",
					"type": "string"
				},
				"as_of": {
					"format": "date-time",
					"title": "As Of",
					"type": "string"
				},
				"spot": {
					"anyOf": [
						{
							"type": "number"
						},
						{
							"pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
							"type": "string"
						}
					],
					"title": "Spot"
				},
				"risk_free_rate": {
					"default": 0.0525,
					"title": "Risk Free Rate",
					"type": "number"
				},
				"contracts": {
					"items": {
						"$ref": "#/$defs/OptionContract"
					},
					"title": "Contracts",
					"type": "array"
				},
				"source": {
					"default": "yfinance",
					"title": "Source",
					"type": "string"
				},
				"degraded": {
					"default": false,
					"description": "True when data quality is poor (missing OI/quotes/IV)",
					"title": "Degraded",
					"type": "boolean"
				}
			},
			"required": ["underlying", "as_of", "spot"],
			"title": "OptionChain",
			"type": "object"
		},
		"Regime": {
			"description": "Coarse market regime tag attached to features/signals.",
			"enum": [
				"trend_up",
				"trend_down",
				"range",
				"high_vol",
				"low_vol",
				"positive_gamma",
				"negative_gamma",
				"unknown"
			],
			"title": "Regime",
			"type": "string"
		},
		"FeatureSnapshot": {
			"additionalProperties": false,
			"properties": {
				"symbol": {
					"title": "Symbol",
					"type": "string"
				},
				"timeframe": {
					"$ref": "#/$defs/Timeframe"
				},
				"ts": {
					"format": "date-time",
					"title": "Ts",
					"type": "string"
				},
				"features": {
					"additionalProperties": {
						"anyOf": [
							{
								"type": "number"
							},
							{
								"type": "null"
							}
						]
					},
					"title": "Features",
					"type": "object"
				},
				"meta": {
					"additionalProperties": true,
					"title": "Meta",
					"type": "object"
				},
				"regime": {
					"$ref": "#/$defs/Regime",
					"default": "unknown"
				},
				"source_version": {
					"default": "0.1.0",
					"title": "Source Version",
					"type": "string"
				}
			},
			"required": ["symbol", "timeframe", "ts"],
			"title": "FeatureSnapshot",
			"type": "object"
		},
		"Analog": {
			"additionalProperties": false,
			"description": "A historically similar setup. forward_return/outcome filled by the ML phase.",
			"properties": {
				"date": {
					"format": "date",
					"title": "Date",
					"type": "string"
				},
				"symbol": {
					"title": "Symbol",
					"type": "string"
				},
				"similarity": {
					"maximum": 1.0,
					"minimum": 0.0,
					"title": "Similarity",
					"type": "number"
				},
				"outcome": {
					"anyOf": [
						{
							"type": "string"
						},
						{
							"type": "null"
						}
					],
					"default": null,
					"title": "Outcome"
				},
				"forward_return": {
					"anyOf": [
						{
							"type": "number"
						},
						{
							"type": "null"
						}
					],
					"default": null,
					"title": "Forward Return"
				}
			},
			"required": ["date", "symbol", "similarity"],
			"title": "Analog",
			"type": "object"
		},
		"EvidenceItem": {
			"additionalProperties": false,
			"description": "A single piece of weighted evidence for or against a thesis.",
			"properties": {
				"kind": {
					"$ref": "#/$defs/EvidenceKind"
				},
				"label": {
					"title": "Label",
					"type": "string"
				},
				"value": {
					"anyOf": [
						{
							"type": "number"
						},
						{
							"type": "string"
						}
					],
					"title": "Value"
				},
				"weight": {
					"description": "Relative importance 0..1",
					"maximum": 1.0,
					"minimum": 0.0,
					"title": "Weight",
					"type": "number"
				},
				"direction": {
					"$ref": "#/$defs/Side",
					"description": "LONG/SHORT lean this item supports (NEUTRAL if context)"
				},
				"source": {
					"default": "engine",
					"title": "Source",
					"type": "string"
				},
				"detail": {
					"anyOf": [
						{
							"type": "string"
						},
						{
							"type": "null"
						}
					],
					"default": null,
					"title": "Detail"
				}
			},
			"required": ["kind", "label", "value", "weight", "direction"],
			"title": "EvidenceItem",
			"type": "object"
		},
		"EvidenceKind": {
			"enum": [
				"feature",
				"level",
				"pattern",
				"internal",
				"options",
				"volume",
				"catalyst",
				"time",
				"data_quality"
			],
			"title": "EvidenceKind",
			"type": "string"
		},
		"EvidencePacket": {
			"additionalProperties": false,
			"description": "Full explanation object attached to a ScannerResult / SignalPacket.",
			"properties": {
				"why": {
					"description": "One-paragraph trade thesis",
					"title": "Why",
					"type": "string"
				},
				"why_now": {
					"description": "The trigger condition that just fired",
					"title": "Why Now",
					"type": "string"
				},
				"evidence_for": {
					"items": {
						"$ref": "#/$defs/EvidenceItem"
					},
					"title": "Evidence For",
					"type": "array"
				},
				"evidence_against": {
					"items": {
						"$ref": "#/$defs/EvidenceItem"
					},
					"title": "Evidence Against",
					"type": "array"
				},
				"invalidation": {
					"$ref": "#/$defs/InvalidationRule"
				},
				"historical_analogs": {
					"items": {
						"$ref": "#/$defs/Analog"
					},
					"title": "Historical Analogs",
					"type": "array"
				},
				"confidence": {
					"maximum": 1.0,
					"minimum": 0.0,
					"title": "Confidence",
					"type": "number"
				},
				"generated_at": {
					"format": "date-time",
					"title": "Generated At",
					"type": "string"
				}
			},
			"required": ["why", "why_now", "invalidation", "confidence"],
			"title": "EvidencePacket",
			"type": "object"
		},
		"InvalidationRule": {
			"additionalProperties": false,
			"description": "Structured invalidation: human text plus a machine-checkable condition.",
			"properties": {
				"description": {
					"title": "Description",
					"type": "string"
				},
				"kind": {
					"description": "price | time | structure | internals | options",
					"title": "Kind",
					"type": "string"
				},
				"level": {
					"anyOf": [
						{
							"type": "number"
						},
						{
							"type": "null"
						}
					],
					"default": null,
					"title": "Level"
				},
				"comparator": {
					"anyOf": [
						{
							"type": "string"
						},
						{
							"type": "null"
						}
					],
					"default": null,
					"description": "lt | gt | crosses",
					"title": "Comparator"
				},
				"expires_at": {
					"anyOf": [
						{
							"format": "date-time",
							"type": "string"
						},
						{
							"type": "null"
						}
					],
					"default": null,
					"title": "Expires At"
				}
			},
			"required": ["description", "kind"],
			"title": "InvalidationRule",
			"type": "object"
		},
		"Side": {
			"enum": ["LONG", "SHORT", "NEUTRAL"],
			"title": "Side",
			"type": "string"
		},
		"ScannerResult": {
			"additionalProperties": false,
			"description": "One scanner's verdict for one symbol/timeframe at one point in time.",
			"properties": {
				"id": {
					"format": "uuid",
					"title": "Id",
					"type": "string"
				},
				"run_id": {
					"anyOf": [
						{
							"format": "uuid",
							"type": "string"
						},
						{
							"type": "null"
						}
					],
					"default": null,
					"title": "Run Id"
				},
				"scanner_id": {
					"title": "Scanner Id",
					"type": "string"
				},
				"symbol": {
					"title": "Symbol",
					"type": "string"
				},
				"timeframe": {
					"$ref": "#/$defs/Timeframe"
				},
				"ts": {
					"format": "date-time",
					"title": "Ts",
					"type": "string"
				},
				"triggered": {
					"title": "Triggered",
					"type": "boolean"
				},
				"direction": {
					"anyOf": [
						{
							"$ref": "#/$defs/Side"
						},
						{
							"type": "null"
						}
					],
					"default": null
				},
				"score": {
					"description": "Confidence 0..1",
					"maximum": 1.0,
					"minimum": 0.0,
					"title": "Score",
					"type": "number"
				},
				"classification": {
					"description": "Scanner-specific label, e.g. 'reversal_long', 'no_trade'",
					"title": "Classification",
					"type": "string"
				},
				"levels": {
					"additionalProperties": {
						"anyOf": [
							{
								"type": "number"
							},
							{
								"pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
								"type": "string"
							}
						]
					},
					"description": "Named price levels: entry/poc/wall/flip/...",
					"title": "Levels",
					"type": "object"
				},
				"feature_refs": {
					"additionalProperties": {
						"anyOf": [
							{
								"type": "number"
							},
							{
								"type": "null"
							}
						]
					},
					"description": "Snapshot of key feature inputs",
					"title": "Feature Refs",
					"type": "object"
				},
				"evidence": {
					"$ref": "#/$defs/EvidencePacket"
				},
				"params": {
					"additionalProperties": true,
					"title": "Params",
					"type": "object"
				}
			},
			"required": [
				"scanner_id",
				"symbol",
				"timeframe",
				"ts",
				"triggered",
				"score",
				"classification",
				"evidence"
			],
			"title": "ScannerResult",
			"type": "object"
		},
		"ScannerSpec": {
			"additionalProperties": false,
			"description": "Self-describing scanner metadata exposed to the dashboard.",
			"properties": {
				"scanner_id": {
					"title": "Scanner Id",
					"type": "string"
				},
				"name": {
					"title": "Name",
					"type": "string"
				},
				"description": {
					"title": "Description",
					"type": "string"
				},
				"category": {
					"description": "e.g. structure | volume | options_gamma | internals",
					"title": "Category",
					"type": "string"
				},
				"params_schema": {
					"additionalProperties": true,
					"description": "JSON Schema of the scanner's params",
					"title": "Params Schema",
					"type": "object"
				},
				"default_params": {
					"additionalProperties": true,
					"title": "Default Params",
					"type": "object"
				}
			},
			"required": ["scanner_id", "name", "description", "category"],
			"title": "ScannerSpec",
			"type": "object"
		},
		"SignalState": {
			"description": "Lifecycle of a signal from proposal to terminal state.",
			"enum": ["PROPOSED", "ACTIVE", "TRIGGERED", "INVALIDATED", "EXPIRED", "FILLED"],
			"title": "SignalState",
			"type": "string"
		},
		"TradeStyle": {
			"enum": ["scalp", "intraday", "swing", "position", "investment"],
			"title": "TradeStyle",
			"type": "string"
		},
		"SignalPacket": {
			"additionalProperties": false,
			"properties": {
				"signal_id": {
					"format": "uuid",
					"title": "Signal Id",
					"type": "string"
				},
				"run_id": {
					"anyOf": [
						{
							"format": "uuid",
							"type": "string"
						},
						{
							"type": "null"
						}
					],
					"default": null,
					"title": "Run Id"
				},
				"source_scanner": {
					"title": "Source Scanner",
					"type": "string"
				},
				"schema_version": {
					"default": "1.0.0",
					"title": "Schema Version",
					"type": "string"
				},
				"created_at": {
					"format": "date-time",
					"title": "Created At",
					"type": "string"
				},
				"symbol": {
					"title": "Symbol",
					"type": "string"
				},
